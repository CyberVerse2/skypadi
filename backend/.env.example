# Required
PORT=8787
HOST=0.0.0.0

# Optional — set both to enable the Telegram bot
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
WAKANOW_BASE_URL=https://www.wakanow.com
WAKANOW_LOCALE=en-NG
WAKANOW_CURRENCY=NGN
WAKANOW_TIMEZONE=Africa/Lagos
WAKANOW_HEADLESS=true
WAKANOW_TIMEOUT_MS=120000
WAKANOW_MAX_RESULTS=10

# Stellar wallets (required)
# STELLAR_NETWORK: testnet | mainnet (default: testnet)
# WALLET_ENCRYPTION_KEY: 32 bytes as hex (64 chars) or base64.
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STELLAR_NETWORK=testnet
WALLET_ENCRYPTION_KEY=
