# Server
PORT=8787
HOST=0.0.0.0
PGSSLMODE=prefer

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/skypadi

# Worker
WORKER_CONCURRENCY=1

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PASSENGER_DETAILS_FLOW_ID=

# AI intent extraction
OPENAI_API_KEY=
OPENAI_INTENT_MODEL=gpt-5.4-mini

# Resend inbound email
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_INBOUND_DOMAIN=bookings.skypadi.com

# Wakanow
WAKANOW_BASE_URL=https://www.wakanow.com
WAKANOW_LOCALE=en-NG
WAKANOW_CURRENCY=NGN
WAKANOW_TIMEZONE=Africa/Lagos
WAKANOW_MAX_RESULTS=50
WAKANOW_ACCOUNT_EMAIL=amaka.nwosu@bookings.skypadi.com
WAKANOW_ACCOUNT_PASSWORD=
WAKANOW_ACCOUNT_1_EMAIL=amaka.nwosu@bookings.skypadi.com
WAKANOW_ACCOUNT_1_PASSWORD=
WAKANOW_ACCOUNT_2_EMAIL=tolu.adebayo@bookings.skypadi.com
WAKANOW_ACCOUNT_2_PASSWORD=
WAKANOW_ACCOUNT_3_EMAIL=chinedu.okoro@bookings.skypadi.com
WAKANOW_ACCOUNT_3_PASSWORD=
WAKANOW_ACCOUNT_4_EMAIL=zainab.bello@bookings.skypadi.com
WAKANOW_ACCOUNT_4_PASSWORD=
PROXY_URL=

# Stellar wallets
# STELLAR_NETWORK: testnet | mainnet (default: testnet)
# WALLET_ENCRYPTION_KEY: 32 bytes as hex (64 chars) or base64.
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STELLAR_NETWORK=testnet
WALLET_ENCRYPTION_KEY=
