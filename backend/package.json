{
  "name": "skypadi-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "npm run typecheck && npm run bundle",
    "bundle": "npm run bundle:web && npm run bundle:worker",
    "bundle:web": "esbuild src/index.ts --bundle --platform=node --format=esm --target=es2022 --packages=external --outfile=dist/index.js",
    "bundle:worker": "esbuild src/worker.ts --bundle --platform=node --format=esm --target=es2022 --packages=external --outfile=dist/worker.js",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "verify": "npm run typecheck && npm run typecheck:test && npm run test:all && npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test:unit": "vitest run tests/unit",
    "test:workflow": "vitest run tests/workflow",
    "test:integration": "vitest run tests/integration",
    "test:all": "npm run test:unit && npm run test:workflow && npm run test:integration && npm run typecheck:test",
    "test:resend-inbound": "vitest run tests/resend-inbound-classification.test.ts",
    "airports:update": "tsx scripts/update-wakanow-airports.ts",
    "airports:update:full": "tsx scripts/update-wakanow-airports.ts --full"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@stellar/stellar-sdk": "^15.0.1",
    "ai": "^6.0.156",
    "axios": "^1.15.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "graphile-worker": "^0.16.6",
    "hpagent": "^1.2.0",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "undici": "^8.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
