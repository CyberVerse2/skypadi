{
  "name": "skypadi-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "tsx scripts/smoke-search.ts",
    "cli": "node --import tsx scripts/cli.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@stellar/stellar-sdk": "^15.0.1",
    "ai": "^6.0.156",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "grammy": "^1.42.0",
    "hpagent": "^1.2.0",
    "playwright": "^1.55.0",
    "undici": "^8.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.8.3"
  }
}
