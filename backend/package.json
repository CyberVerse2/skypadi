{
  "name": "skypadi-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "smoke:stealth": "tsx scripts/smoke-stealth.ts",
    "test:bot-contract": "tsx scripts/check-bot-booking-contract.ts",
    "test:unit": "tsx tests/unit/test-harness.test.ts && tsx tests/unit/schema.test.ts && tsx tests/unit/domain-types.test.ts && tsx tests/unit/whatsapp.mapper.test.ts && tsx tests/unit/flight-ranking.test.ts",
    "test:workflow": "tsx tests/workflow/conversation.workflow.test.ts && tsx tests/workflow/booking.workflow.test.ts && tsx tests/workflow/supplier-booking.workflow.test.ts && tsx tests/workflow/payment.workflow.test.ts",
    "test:integration": "tsx tests/integration/whatsapp.routes.test.ts",
    "test:all": "npm run test:unit && npm run test:workflow && npm run test:integration && npm run typecheck:test",
    "test:resend-inbound": "tsx tests/resend-inbound-classification.test.ts",
    "test:book": "tsx scripts/test-book.ts",
    "trace:analyze": "tsx scripts/analyze-trace.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@stellar/stellar-sdk": "^15.0.1",
    "ai": "^6.0.156",
    "axios": "^1.15.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "fingerprint-generator": "^2.1.82",
    "fingerprint-injector": "^2.1.82",
    "grammy": "^1.42.0",
    "hpagent": "^1.2.0",
    "patchright": "^1.59.4",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "undici": "^8.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1",
    "typescript": "^5.8.3"
  }
}
